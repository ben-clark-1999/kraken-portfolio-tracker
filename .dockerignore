# Secrets — never bake into the image.
.env
.env.*
!.env.example

# Version control + meta
.git
.gitignore
.gitattributes

# Python build artefacts
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.venv
**/venv

# Frontend — not part of the backend image.
frontend
node_modules

# Tests aren't needed at runtime.
backend/tests

# Local-only / editor files
.claude
.agents
.impeccable.md
docs
*.code-workspace
*.log

# Skill / plan caches
skills-lock.json
up.txt
